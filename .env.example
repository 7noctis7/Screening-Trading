# Copiez ce fichier en `.env` (jamais committé) et renseignez vos clés.
# Aucune clé ici n'est obligatoire : sans elles, tout tourne en paper / synthétique.

# --- Alpaca (actions & ETF US, PAPER) ---
# Créez un compte PAPER sur https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- Bitmart (crypto, paires /USDC) ---
# https://www.bitmart.com → Account → API Management (permissions: lecture + spot trade ; JAMAIS retrait)
BITMART_API_KEY=
BITMART_API_SECRET=
BITMART_API_MEMO=
# Marché de trading Bitmart : "spot" (défaut, SANS levier — recommandé) ou "swap" (futures = LEVIER).
# ⚠️ Le futures introduit du levier → risque de ruine, contraire à la discipline du système. Spot conseillé.
# BITMART_MARKET=spot
# Poche CRYPTO (best practice, risk-parity) en part du capital. 0 = désactivée (défaut).
# Ex. 0.15 = 15 % crypto / 85 % actions. Nécessite des fonds Bitmart SPOT.
# QUANT_CRYPTO_PCT=0.15

# --- Données fondamentales réelles (optionnel) ---
# Option A : FMP (clé, free tier ≈40 actifs) — https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# Option B : yfinance (RÉEL, GRATUIT, sans clé) = MAINTENANT LE DÉFAUT quand le réseau répond.
#   Cache disque 24 h (.cache/) → builds rapides ; le cron quotidien le réchauffe.
#   Pour FORCER l'offline/démo (fondamentaux synthétiques) : QUANT_FUND=synthetic
# QUANT_FUND=synthetic

# --- Base de prix réelle (optionnel) ---
# QUANT_PRICE_DB=/Users/votre_nom/Desktop/YAHOO.db
# Profondeur d'historique (jours). Défaut 1700 (~4,6 ans). Pour remonter à ~2016 : 3650 (~10 ans).
# QUANT_HISTORY_DAYS=3650

# --- News réelles (optionnel) : mettre 1 pour activer le flux RSS gratuit ---
# QUANT_NEWS=1
# Modèle NLP : FinBERT générique par défaut. RECOMMANDÉ (meilleur, gratuit) si transformers installé :
# FINBERT_MODEL=yiyanghkust/finbert-tone

# --- Macro chiffrée (optionnel, GRATUIT) : clé FRED → onglet Macro (croissance, inflation, taux…) ---
# https://fred.stlouisfed.org → My Account → API Keys
# FRED_API_KEY=

# --- Alerte earnings (optionnel) : 1 = signale les résultats imminents sur les positions ---
# QUANT_EARNINGS=1

# --- IA locale (optionnel) : LM Studio / Ollama (compatible OpenAI) ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=
# Ollama (FinOps : décharge les tâches simples sur un modèle local gratuit) :
# OLLAMA_HOST=http://127.0.0.1:11434
# QUANT_LOCAL_LLM=gemma3n:e4b           # modèle local pour cheap_llm/smart_text (ollama pull gemma3n:e4b)
# QUANT_EMBED=ollama                    # RAG vault dense (ollama pull nomic-embed-text)

# --- Miroir Obsidian → Notion (gratuit, scripts/notion_sync.py) ---
# Intégration : notion.so → My integrations → secret ; partager la page parente avec l'intégration.
# NOTION_TOKEN=ntn_xxxxxxxxxxxx
# NOTION_PARENT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ID (32 hex) de la page Notion parente

# --- Sécurité API (durcissement) ---
# CORS verrouillé sur localhost par défaut. N'élargir QUE si tu exposes l'API (jamais "*" en réseau ouvert) :
# QUANT_CORS_ORIGINS=https://mon-domaine.example
# Jeton pour le webhook TradingView (/api/tv/webhook). Si vide → endpoint accessible UNIQUEMENT en localhost.
# QUANT_WEBHOOK_TOKEN=change-moi-en-chaine-aleatoire-longue

# --- Cache OHLCV Hugging Face (gratuit, versionné) ---
# Dataset PUBLIC → lecture sans token (CI) ; seul le `make hf-push` (rafraîchissement) requiert le token.
# Token fine-grained limité au seul dataset (Write). Ne JAMAIS committer .env (gitignoré + gitleaks).
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# HF_DATASET=Noctis777/screening-trading-cache
