# Copiez ce fichier en `.env` (jamais committé) et renseignez vos clés.
# Aucune clé ici n'est obligatoire : sans elles, tout tourne en paper / synthétique.

# --- Alpaca (actions & ETF US, PAPER) ---
# Créez un compte PAPER sur https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- Bitmart (crypto, paires /USDC) ---
# https://www.bitmart.com → Account → API Management (permissions: lecture + spot trade ; JAMAIS retrait)
BITMART_API_KEY=
BITMART_API_SECRET=
BITMART_API_MEMO=

# --- Données fondamentales réelles (optionnel) ---
# Option A : FMP (clé, free tier ≈40 actifs) — https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# Option B : yfinance (RÉEL, GRATUIT, sans clé, ~80 actifs car plus lent) → décommente :
# QUANT_FUND=yf
# Sans rien : fondamentaux SYNTHÉTIQUES (fabriqués, pour la démo — pas pour décider).

# --- Base de prix réelle (optionnel) ---
# QUANT_PRICE_DB=/Users/votre_nom/Desktop/YAHOO.db

# --- News réelles (optionnel) : mettre 1 pour activer le flux RSS gratuit ---
# QUANT_NEWS=1

# --- IA locale (optionnel) : LM Studio / Ollama (compatible OpenAI) ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=
